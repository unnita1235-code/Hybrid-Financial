# Supabase (public URL + key). Copy to `.env.local`. Dashboard:
# https://supabase.com/dashboard → Project → Settings → API
#
# Used by: browser client, server client, and middleware (auto session refresh + cookies)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Prefer the default publishable key; legacy anon JWT works too
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
