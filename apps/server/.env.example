DATABASE_URL=postgresql+asyncpg://aequitas:aequitas_dev@localhost:5432/aequitas

# Auth / RBAC: none | dev | supabase | clerk
#   dev: trust X-User-Id, X-User-Role (local + tests)
#   supabase: verify HS256 with SUPABASE_JWT_SECRET; role in app_metadata.role
#   clerk: RS256 via CLERK_JWKS_URL; role in public_metadata
AUTH_PROVIDER=dev
# CLERK_JWKS_URL=
# CLERK_AUTHORIZED_PARTIES=

# Supabase (server) — same project as the Next.js app. Public browser vars: see ../web/.env.example
#   SUPABASE_URL = same value as NEXT_PUBLIC_SUPABASE_URL (e.g. https://YOUR_PROJECT_REF.supabase.co)
#   SUPABASE_SERVICE_KEY = secret key (RAG, ingest vector mirror, PostgREST) — never use in the browser; not the publishable key
#   SUPABASE_JWT_SECRET = JWT signing secret when AUTH_PROVIDER=supabase (Project Settings → API)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_JWT_SECRET=

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
SQL_MODEL=o3-mini
SYNTHESIS_MODEL=claude-3-5-sonnet-20241022
# LangGraph Postgres checkpointer (Temporal thread memory). false = in-memory only.
# USE_POSTGRES_CHECKPOINTER=true
# If true, do not fall back to MemorySaver when checkpointer init fails (stricter for CI).
# CHECKPOINTER_POSTGRES_REQUIRED=false
# Shadow analyst (APScheduler every 6h) — set false to disable
# SHADOW_ANALYST_ENABLED=true
# NEWS_API_KEY=          # e.g. newsapi.org; optional, deep research still runs RAG
# NEWS_API_URL=https://newsapi.org/v2/everything
